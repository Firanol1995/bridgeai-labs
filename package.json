{
  "name": "bridgeai-labs",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/build-production.mjs",
    "build:worker": "tsc --outDir dist --skipLibCheck",
    "worker:run": "node dist/backend/workers/embeddingProcessor.js",
    "worker:docker:up": "docker-compose -f docker-compose.worker.yml up --build -d",
    "start": "node scripts/start-production.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify-release.mjs",
    "db:check": "node scripts/check_db.cjs",
    "db:apply-rls": "powershell -File scripts/apply_rls.ps1",
    "db:seed": "node prisma/seed.mjs",
    "validate:startup-env": "node scripts/validate-startup-env.mjs"
  },
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "@sentry/core": "^8.55.0",
    "@sentry/node": "^8.55.0",
    "@sentry/react": "^8.55.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-table": "^8.21.3",
    "bullmq": "^5.70.1",
    "ioredis": "^5.10.0",
    "next": "16.1.6",
    "node-fetch": "^3.3.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pg": "^8.11.0",
    "prisma": "^4.16.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^1.3.0"
  }
}
